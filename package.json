{
  "name": "power-snip-app",
  "version": "1.0.0",
  "private": true,
  "description": "Power Snip! — Capacitor native shell (iOS + Android)",
  "scripts": {
    "ios:add": "npx cap add ios && npx cap sync ios",
    "android:add": "npx cap add android && npx cap sync android",
    "assets": "npx @capacitor/assets generate --android --ios",
    "open:ios": "npx cap open ios",
    "open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/android": "^7.6.8",
    "@capacitor/core": "^7.6.8",
    "@capacitor/ios": "^7.6.8",
    "@capacitor/share": "^7.0.1",
    "@capacitor/splash-screen": "^7.0.5",
    "cordova-plugin-purchase": "^13.18.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.6.8"
  }
}
